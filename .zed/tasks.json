[
  {
    "label": "Bundle",
    "command": "cargo bundle >/dev/null 2>&1",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "Bundle and Run",
    "command": "cargo bundle >/dev/null 2>&1 && cargo run",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "Code Reset",
    "command": "git reset --hard >/dev/null 2>&1",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never"
  }
]
